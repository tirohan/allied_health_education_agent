APP_ENV=local
LOG_LEVEL=INFO
API_KEY=local-dev-key

# Local (non-Docker) Postgres URL
DATABASE_URL=postgresql://tanbinislam@localhost:5432/allied_health_edu

# Docker Compose overrides DATABASE_URL with this value so containers
# can reach Postgres on the host machine. Adjust user/db/password as needed.
DOCKER_DATABASE_URL=postgresql://tanbinislam@host.docker.internal:5432/allied_health_edu

POSTGRES_MIN_SIZE=1
POSTGRES_MAX_SIZE=10

# Local defaults. Docker Compose overrides these to service hostnames.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_VECTOR_SIZE=1536

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CACHE_TTL_SECONDS=86400
MINDMAP_MAX_NODES=50
